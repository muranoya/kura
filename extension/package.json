{
  "name": "kura-extension",
  "version": "0.1.7",
  "description": "kura - サーバ不要のパスワードマネージャー ブラウザ拡張機能",
  "author": "Daisuke Muraoka <daisuke.muraoka.jp@gmail.com>",
  "homepage": "https://github.com/muranoya/kura",
  "repository": {
    "type": "git",
    "url": "https://github.com/muranoya/kura.git"
  },
  "bugs": {
    "url": "https://github.com/muranoya/kura/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "vite",
    "build": "pnpm exec tsx scripts/generate-etld.ts && pnpm exec tsx scripts/generate-patterns.ts && vite build",
    "build:firefox": "pnpm exec tsx scripts/generate-etld.ts && pnpm exec tsx scripts/generate-patterns.ts && vite build --config vite.config.firefox.ts",
    "generate-etld": "pnpm exec tsx scripts/generate-etld.ts",
    "generate-patterns": "pnpm exec tsx scripts/generate-patterns.ts",
    "update-psl": "pnpm exec tsx scripts/update-psl.ts",
    "preview": "vite preview",
    "check": "biome check .",
    "fix": "biome check --write .",
    "test": "vitest run",
    "test:manual": "pnpm exec tsx test-pages/server.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-label": "^2",
    "@radix-ui/react-scroll-area": "^1",
    "@radix-ui/react-select": "^2",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-slot": "^1",
    "@smithy/fetch-http-handler": "^4",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "i18next": "^26.0.6",
    "lucide-react": "^1",
    "qrcode.react": "^4",
    "react": "^19",
    "react-dom": "^19",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10",
    "react-router-dom": "^7",
    "remark-gfm": "^4",
    "tailwind-merge": "^3",
    "webextension-polyfill": "^0.12",
    "zustand": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@crxjs/vite-plugin": "^2",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/webextension-polyfill": "^0.12",
    "@vitejs/plugin-react": "^6",
    "jsdom": "^26",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^6",
    "vite": "^8",
    "vite-plugin-wasm": "^3",
    "vitest": "^3",
    "web-ext": "^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome"
    ]
  }
}
