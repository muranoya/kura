{
  "manifest_version": 3,
  "name": "kura",
  "version": "0.1.0",
  "description": "サーバ不要、自分一人のための、運用コストゼロのパスワードマネージャー",

  "permissions": ["storage", "alarms", "clipboardWrite", "offscreen", "tabs"],

  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/locked-16.png",
      "48": "icons/locked-48.png",
      "128": "icons/locked-128.png"
    }
  },

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "offscreen_documents": [
    {
      "document": "src/background/offscreen.html",
      "matches": ["<all_urls>"],
      "reasons": ["CLIPBOARD"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["wasm/wasm_bridge_bg.wasm", "src/content/dropdown.css"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/main.ts"],
      "run_at": "document_idle"
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
