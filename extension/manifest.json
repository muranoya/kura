{
  "manifest_version": 3,
  "name": "kura",
  "version": "0.1.4",
  "description": "サーバ不要、自分一人のためのパスワードマネージャー",

  "permissions": ["storage", "alarms", "clipboardWrite", "clipboardRead", "offscreen", "tabs"],

  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/locked-16.png",
      "48": "icons/locked-48.png",
      "128": "icons/locked-128.png"
    }
  },

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "wasm/wasm_bridge_bg.wasm",
        "src/content/dropdown.css",
        "src/content/capture.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/main.ts"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
