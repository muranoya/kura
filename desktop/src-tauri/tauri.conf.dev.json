{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kura",
  "version": "0.1.0",
  "identifier": "net.meshpeak.kura",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "kura",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "devtools": true
      }
    ],
    "enableGTKAppId": true,
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/locked.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "kura"
    }
  },
  "plugins": {}
}
